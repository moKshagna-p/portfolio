---
import '../styles/global.css';

const github = 'https://github.com/moKshagna-p';
const email = 'mailto:mokshagnareddy45@gmail.com';

const writings = [
  {
    title: 'shipping small, sharp interfaces',
    href: 'https://github.com/moKshagna-p',
  },
  {
    title: 'why simple systems last longer',
    href: 'https://github.com/moKshagna-p',
  },
  {
    title: 'astro and bun make a clean stack',
    href: 'https://github.com/moKshagna-p',
  },
  {
    title: 'designing for speed without noise',
    href: 'https://github.com/moKshagna-p',
  },
  {
    title: 'products should feel invisible',
    href: 'https://github.com/moKshagna-p',
  },
];
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Mokshagna Reddy — Portfolio</title>
    <meta
      name="description"
      content="Mokshagna Reddy — a single-screen portfolio built with Bun and Astro."
    />
    <meta name="author" content="Mokshagna Reddy" />
    <meta name="theme-color" content="#000000" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Oooh+Baby&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <main class="page">
      <header class="hero" aria-labelledby="name">
        <svg
          class="wordmark"
          id="name"
          viewBox="0 0 1040 210"
          role="img"
          aria-label="Mokshagna Reddy"
        >
          <text x="6" y="150">Mokshagna Reddy</text>
        </svg>

        <p class="lede">
          i’m a software engineer focused on thoughtful interfaces, clean product
          systems, and frontend work that feels effortless. i like building things that
          stay simple even when the problem is not.
        </p>
        <p class="lede">
          before focusing on product interfaces, i spent time shipping across web and
          mobile. i care about making complex systems accessible, fast, and quiet in
          the best possible way.
        </p>
      </header>

      <footer class="footer">
        <nav aria-labelledby="writings-title">
          <p class="section-label" id="writings-title">favorite writings:</p>
          <ul class="link-list">
            {writings.map((writing) => (
              <li>
                <a href={writing.href} target="_blank" rel="noopener noreferrer">
                  {writing.title}
                </a>
              </li>
            ))}
          </ul>
        </nav>

        <div class="footer-bottom">
          <button id="theme-toggle" class="theme-toggle">
            <span class="theme-label">theme:</span> <span id="theme-name">midnight</span>
          </button>
          <div class="meta-links" aria-label="External contact links">
            <a href={github} target="_blank" rel="me noopener noreferrer">
              github
            </a>
            <a href={email}>email</a>
          </div>
        </div>
      </footer>
    </main>

    <script>
      // Theme Cycler
      const themes = ['midnight', 'parchment', 'graphite'];
      let currentThemeIndex = 0;
      
      const themeToggle = document.getElementById('theme-toggle');
      const themeName = document.getElementById('theme-name');
      
      if (themeToggle && themeName) {
        themeToggle.addEventListener('click', () => {
          currentThemeIndex = (currentThemeIndex + 1) % themes.length;
          const newTheme = themes[currentThemeIndex];
          
          document.documentElement.dataset.theme = newTheme;
          
          // Animate the text change
          themeName.style.opacity = '0';
          themeName.style.transform = 'translateY(4px)';
          
          setTimeout(() => {
            themeName.innerText = newTheme;
            themeName.style.opacity = '1';
            themeName.style.transform = 'translateY(0)';
          }, 200);
        });
      }
    </script>
  </body>
</html>
